  <classes name="ANM200" pogoRevision="9.1">
    <description description="Controls Attocube ANM200 piezo DC motors via three DoubleOutBeckhoff proxies. x, y, z positions are stored internally; writes send scaled voltages to the Beckhoff DAC outputs." title="Attocube ANM200 piezo motor control" sourcePath="/home/intermag/TangoServers/ANM200" language="PythonHL" filestogenerate="XMI   file,Code files,Protected Regions" license="GPL" copyright="" hasMandatoryProperty="false" hasConcreteProperty="true" hasAbstractCommand="false" hasAbstractAttribute="false">
      <inheritances classname="Device_Impl" sourcePath=""/>
      <identification contact="at mat.ethz.ch - christoph.murer" author="christoph.murer" emailDomain="mat.ethz.ch" classFamily="Motion" siteSpecific="" platform="Unix Like" bus="Ethernet" manufacturer="Attocube" reference=""/>
    </description>
    <deviceProperties name="Socketx" description="TANGO path to DoubleOutBeckhoff for x axis">
      <type xsi:type="pogoDsl:StringType"/>
      <status abstract="false" inherited="false" concrete="true" concreteHere="true"/>
      <DefaultPropValue>hpp-n42/beckhoff/AOC1</DefaultPropValue>
    </deviceProperties>
    <deviceProperties name="Sockety" description="TANGO path to DoubleOutBeckhoff for y axis">
      <type xsi:type="pogoDsl:StringType"/>
