  <classes name="AttoDRY" pogoRevision="9.1">
    <description description="Connects to the AttoDRY2100 cryostat via UDP to a Windows PC running AttoDRY2100 software. A daemon listener thread polls the state every 0.2 s." title="AttoDRY2100 cryostat control" sourcePath="/home/intermag/TangoServers/AttoDRY" language="PythonHL" filestogenerate="XMI   file,Code files,Protected Regions" license="GPL" copyright="" hasMandatoryProperty="false" hasConcreteProperty="true" hasAbstractCommand="false" hasAbstractAttribute="false">
      <inheritances classname="Device_Impl" sourcePath=""/>
      <identification contact="at mat.ethz.ch - christoph.murer" author="christoph.murer" emailDomain="mat.ethz.ch" classFamily="Temperature" siteSpecific="" platform="All Platforms" bus="Ethernet" manufacturer="attocube" reference="attocube2100"/>
    </description>
    <deviceProperties name="AttoIP" description="IP address of the Windows PC running AttoDRY2100 software">
      <type xsi:type="pogoDsl:StringType"/>
      <status abstract="false" inherited="false" concrete="true" concreteHere="true"/>
      <DefaultPropValue>192.168.1.8</DefaultPropValue>
    </deviceProperties>
    <deviceProperties name="AttoPort" description="UDP port on the Windows PC">
      <type xsi:type="pogoDsl:DoubleType"/>
      <status abstract="false" inherited="false" concrete="true" concreteHere="true"/>
      <DefaultPropValue>11000</DefaultPropValue>
    </deviceProperties>
    <deviceProperties name="LocalIP" description="IP address of the local network interface to bind to">
      <type xsi:type="pogoDsl:StringType"/>
      <status abstract="false" inherited="false" concrete="true" concreteHere="true"/>
      <DefaultPropValue>192.168.1.7</DefaultPropValue>
    </deviceProperties>
    <deviceProperties name="LocalPort" description="UDP port to bind on this machine">
      <type xsi:type="pogoDsl:IntType"/>
      <status abstract="false" inherited="false" concrete="true" concreteHere="true"/>
      <DefaultPropValue>11005</DefaultPropValue>
    </deviceProperties>
