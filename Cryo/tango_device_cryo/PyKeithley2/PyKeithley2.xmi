  <classes name="PyKeithley2" pogoRevision="9.1">
    <description description="Controls a Keithley 6221 current source (unit 2) via a Socket TANGO device. Supports DC current output and sine-wave generation with external trigger on phase marker output line 3." title="PyKeithley2 - Keithley 6221 current source (unit 2)" sourcePath="/home/intermag/TangoServers/PyKeithley2" language="PythonHL" filestogenerate="XMI   file,Code files,Protected Regions" license="GPL" copyright="" hasMandatoryProperty="false" hasConcreteProperty="true" hasAbstractCommand="false" hasAbstractAttribute="false">
      <inheritances classname="Device_Impl" sourcePath=""/>
      <identification contact="at mat.ethz.ch - christoph.murer" author="christoph.murer" emailDomain="mat.ethz.ch" classFamily="PowerSupply" siteSpecific="" platform="Unix Like" bus="Socket" manufacturer="Keithley" reference=""/>
    </description>
    <deviceProperties name="SocketProxy" description="TANGO path to the Socket device connected to Keithley unit 2">
      <type xsi:type="pogoDsl:StringType"/>
      <status abstract="false" inherited="false" concrete="true" concreteHere="true"/>
      <DefaultPropValue>hpp-n42/socket/keithley6221_2</DefaultPropValue>
    </deviceProperties>
