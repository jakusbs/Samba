        <type xsi:type="pogoDsl:ConstStringType"/>
      </argout>
      <status abstract="true" inherited="true" concrete="true"/>
    </commands>
    <commands name="ON" description="Enable the current output" execMethod="on" displayLevel="OPERATOR" polledPeriod="0" isDynamic="false">
