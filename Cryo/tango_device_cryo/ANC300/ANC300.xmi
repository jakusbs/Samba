  <classes name="ANC300" pogoRevision="9.1">
    <description description="Controls an Attocube ANC300 piezo controller via a Socket TANGO proxy using the ANC300 serial-over-Ethernet ASCII protocol." title="ANC300 piezo stepper controller" sourcePath="/home/intermag/TangoServers/ANC300" language="PythonHL" filestogenerate="XMI   file,Code files,Protected Regions" license="GPL" copyright="" hasMandatoryProperty="false" hasConcreteProperty="true" hasAbstractCommand="false" hasAbstractAttribute="false">
      <inheritances classname="Device_Impl" sourcePath=""/>
      <identification contact="at mat.ethz.ch - christoph.murer" author="christoph.murer" emailDomain="mat.ethz.ch" classFamily="Motion" siteSpecific="" platform="All Platforms" bus="Socket" manufacturer="Attocube" reference=""/>
    </description>
    <deviceProperties name="Proxy" description="TANGO path to the Socket device connected to the ANC300">
      <type xsi:type="pogoDsl:StringType"/>
      <status abstract="false" inherited="false" concrete="true" concreteHere="true"/>
      <DefaultPropValue>hpp-N42/socket/ANC300</DefaultPropValue>
    </deviceProperties>
